<?xml version="1.0" encoding="utf-8"?>
<!-- No network I/O: block all cleartext and trust only system CAs if a dependency ever opens TLS. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
